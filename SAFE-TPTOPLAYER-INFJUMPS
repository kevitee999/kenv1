-- Reset state function
local function resetState()
    isEscaped = false
    savedPosition = nil
    groundY = nil
    statusLabel.Text = "Status: Ground"
    statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
end

-- Update character on respawn
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoid = newChar:WaitForChild("Humanoid", 8)
    resetState()
end)

-- Main loop
RunService.Heartbeat:Connect(function()
    if not isEnabled or not humanoid or not character or not character.Parent then
        return
    end

    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local currentHP = humanoid.Health

    -- Update status
    if isEscaped then
        statusLabel.Text = "Status: Escaped (Y: " .. math.floor(hrp.Position.Y) .. ")"
        statusLabel.TextColor3 = Color3.fromRGB(0, 255, 255)
    else
        statusLabel.Text = "Status: Ground (HP: " .. math.floor(currentHP) .. ")"
        statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    end

    -- 1. Detect manual return to ground (key fix!)
    if isEscaped and groundY and hrp.Position.Y < groundY + GROUND_BUFFER then
        resetState()
        print("Detected manual return to ground → reset state (will re-escape if low HP)")
        return  -- Exit early this frame
    end

    -- 2. Escape if low HP
    if currentHP < LOW_HP_THRESHOLD and not isEscaped then
        groundY = hrp.Position.Y
        savedPosition = hrp.CFrame
        
        -- Teleport UP (preserves facing direction now!)
        local newPos = savedPosition.Position + Vector3.new(0, ESCAPE_Y_OFFSET, 0)
        hrp.CFrame = CFrame.lookAt(newPos, newPos + savedPosition.LookVector)
        
        isEscaped = true
        print("Low HP → escaped to Y +" .. ESCAPE_Y_OFFSET)
        return
    end

    -- 3. Auto-return if safe HP
    if currentHP >= SAFE_HP_THRESHOLD and isEscaped and savedPosition then
        hrp.CFrame = savedPosition
        resetState()
        print("HP safe → returned to previous position")
    end
end)

